# WEB session for market capture (incoming public streams → ClickHouse). Required when capture is enabled.
MEXC_SOURCE_WEB_KEY=

# WEB session for trading / private REST (orders, positions). Required when scalper is enabled.
MEXC_WEB_KEY=

# ClickHouse native protocol (bot). In Docker, compose sets CLICKHOUSE_ADDR=clickhouse:9000.
# From the host with default compose ports use 127.0.0.1:19000 (mapped to container 9000).
CLICKHOUSE_ADDR=127.0.0.1:19000
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=mexc_bot

# Comma-separated contract symbols for public WS capture (order book + deals), e.g. TAO_USDT,BTC_USDT
MEXC_WS_SYMBOLS=TAO_USDT

# Optional: before live scalper WS, sample book metrics for this duration (e.g. 20s, 45s). Set to 0 to skip.
# MEXC_SCALPER_WARMUP=20s
# During warmup, log live book/signal snapshot every N (default 2s). Set to 0 to disable interim lines.
# MEXC_SCALPER_WARMUP_PROGRESS=2s
